# Supabase (service role — server-side only, keep secret)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Sumopod (OpenAI-compatible) — get from ai.sumopod.com
SUMOPOD_API_KEY=your-sumopod-key
SUMOPOD_BASE_URL=https://ai.sumopod.com/v1
SUMOPOD_MODEL=deepseek-chat

# The WhatsApp chat the bot listens to (run `npm run discover` once to find it)
ORDERS_CHAT_JID=

# How long (ms) an order-text and a location can be apart and still pair
PAIR_WINDOW_MS=120000

# Set ACK_REPLY=1 to send a one-line "order received" reply (default off)
ACK_REPLY=0

# Only turn YOUR own messages/forwards into orders (1=yes, default). 0=anyone in the chat.
# Used only when ALLOWED_SENDERS is empty.
ONLY_FROM_ME=1

# Phone number(s) allowed to create orders / run commands (comma-separated).
# Set this when the bot runs on a SEPARATE number from your business line: put your
# business number here (any format, e.g. +62 878-3831-2663 or 0878...). When set, this
# takes precedence over ONLY_FROM_ME. Find your number with `npm run discover`.
ALLOWED_SENDERS=
